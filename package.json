{
  "name": "@anoesj/eslint-config-vue-ts",
  "version": "0.5.0",
  "description": "Anoesj's ESLint config for Vue and Nuxt projects with TypeScript",
  "author": "Anoesj Sadraee (https://github.com/anoesj)",
  "license": "MIT",
  "homepage": "https://github.com/anoesj/eslint-config-vue-ts#readme",
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/anoesj/eslint-config-vue-ts.git"
  },
  "bugs": {
    "url": "https://github.com/anoesj/eslint-config-vue-ts/issues"
  },
  "keywords": [
    "eslint",
    "eslintconfig"
  ],
  "scripts": {
    "build": "tsdown",
    "watch": "tsdown --watch",
    "inspect": "eslint-config-inspector",
    "release": "bumpp && pnpm publish --access public"
  },
  "peerDependencies": {
    "eslint": ">= 10"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.5.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3"
  }
}
